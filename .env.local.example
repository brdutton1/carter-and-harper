# Copy this file to .env.local and fill in real values for local dev.
# In production, set these in Vercel → Project → Settings → Environment Variables.
# NEVER commit .env.local — it's git-ignored.

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Resend API key — get one at https://resend.com/api-keys (free tier: 3k/mo)
RESEND_API_KEY=

# Where internal lead notifications go (Carter + Bryan see proposals fly out)
LEAD_NOTIFY_EMAIL=bryan@allegrodesignco.com

# Optional: the "From" address on outgoing emails. Defaults to Resend's test sender.
# Once Carter has a verified domain on Resend, set this to e.g. "Carter & Harper <hello@carterandharper.com>"
RESEND_FROM_EMAIL=
